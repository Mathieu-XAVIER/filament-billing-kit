{
    "name": "mxavier/filament-billing-kit",
    "description": "A Filament v5 plugin for subscription plans, invoices, and entitlements via Stripe Cashier",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "filament",
        "billing",
        "subscriptions",
        "stripe",
        "cashier",
        "saas"
    ],
    "authors": [
        {
            "name": "mxavier",
            "email": "mathieuxavier38150@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "filament/filament": "^5.0",
        "laravel/cashier": "^15.0",
        "spatie/laravel-package-tools": "^1.16"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.0",
        "orchestra/testbench": "^9.0",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0",
        "phpstan/phpstan": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Mxavier\\FilamentBillingKit\\": "src/",
            "Mxavier\\FilamentBillingKit\\Database\\Seeders\\": "database/seeders/",
            "Mxavier\\FilamentBillingKit\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Mxavier\\FilamentBillingKit\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Mxavier\\FilamentBillingKit\\FilamentBillingKitServiceProvider"
            ]
        }
    },
    "scripts": {
        "pint": "pint",
        "pint:test": "pint --test",
        "phpstan": "phpstan analyse --memory-limit=512M",
        "check": [
            "@pint:test",
            "@phpstan"
        ],
        "fix": [
            "@pint",
            "@phpstan"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
